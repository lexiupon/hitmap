def normalize_text(value):
    """Normalize text for case-insensitive matching."""
    return value.strip().casefold()


def dedupe_preserving_order(values):
    """Dedupe strings while preserving their original order."""
    seen = set()
    result = []
    for value in values:
        if not value:
            continue
        marker = normalize_text(value)
        if marker in seen:
            continue
        seen.add(marker)
        result.append(value)
    return tuple(result)


def resolve_repo_root(repo_path):
    """Validate and resolve the target path to a git working tree root."""
    try:
        repo = Repo(repo_path, search_parent_directories=True)
    except (InvalidGitRepositoryError, NoSuchPathError) as exc:
        raise click.ClickException(f"Invalid repository path: {repo_path}") from exc

    if repo.bare:
        raise click.ClickException("Unable to access the git repository")

    return repo.working_tree_dir or repo_path


def resolve_author_selection(all_authors, author_names, author_emails, default_all=False):
    """Resolve the requested author filter."""
    cleaned_names = dedupe_preserving_order(author_names)
    cleaned_emails = dedupe_preserving_order(author_emails)

    if all_authors and (cleaned_names or cleaned_emails):
        raise click.ClickException(
            "--all-authors cannot be combined with --author-name or --author-email"
        )

    if not all_authors and not cleaned_names and not cleaned_emails:
        if default_all:
            all_authors = True
        else:
            raise click.ClickException(
                "Select authors with --all-authors, --author-name, or --author-email"
            )

    return AuthorSelection(
        all_authors=all_authors,
        author_names=cleaned_names,
        author_emails=cleaned_emails,
        normalized_names=frozenset(normalize_text(value) for value in cleaned_names),
        normalized_emails=frozenset(normalize_text(value) for value in cleaned_emails),
    )


def describe_author_selection(selection):
    """Return a concise human-readable author filter description."""
    if selection.all_authors:
        return "all authors"

    parts = []
    if selection.author_names:
        parts.append("name=" + ", ".join(selection.author_names))
    if selection.author_emails:
        parts.append("email=" + ", ".join(selection.author_emails))
    return " or ".join(parts)


def author_matches(selection, author_name, author_email):
    """Return whether an author matches the configured selection."""
    if selection.all_authors:
        return True

    normalized_name = normalize_text(author_name)
    normalized_email = normalize_text(author_email)
    return (
        normalized_name in selection.normalized_names
        or normalized_email in selection.normalized_emails
    )


def format_git_date(input_datetime):
    """Format a datetime for git's date filters."""
    return input_datetime.strftime("%d %b %Y")


def iter_commit_entries(repo_path, start_date=None, end_date=None):
    """Yield commit date, author name, and author email from git log."""
    git_client = git.Git(repo_path)
    args = ["--date=short", "--pretty=format:%ad%x1f%an%x1f%ae"]

    if start_date is not None:
        args.append(f"--since={format_git_date(start_date)}")
    if end_date is not None:
        args.append(f"--before={format_git_date(end_date)}")

    for raw_line in git_client.log(*args).splitlines():
        line = raw_line.strip()
        if not line:
            continue

        parts = line.split("\x1f")
        if len(parts) != 3:
            continue

        try:
            commit_day = date.fromisoformat(parts[0])
        except ValueError:
            continue

        yield commit_day, parts[1], parts[2]


def ensure_author_selection_exists(repo_path, selection):
    """Fail early when the requested author filter matches nothing in the repo."""
    if selection.all_authors:
        return

    for _, author_name, author_email in iter_commit_entries(repo_path):
        if author_matches(selection, author_name, author_email):
            return

    raise click.ClickException(
        "No author matched the requested filters. "
        "Use `hitmap authors REPO --search ...` to inspect available identities."
    )


def collect_commit_day_counts(repo_path, selection, start_date, end_date):
    """Collect per-day commit counts for the selected authors and date range."""
    day_counts = defaultdict(int)
    matched_identities = set()
    total_commits = 0

    for commit_day, author_name, author_email in iter_commit_entries(
        repo_path, start_date, end_date
    ):
        if not author_matches(selection, author_name, author_email):
            continue

        day_counts[commit_day.isoformat()] += 1
        total_commits += 1
        matched_identities.add((author_name, author_email))

    return dict(day_counts), total_commits, matched_identities


def collect_author_summaries(repo_path, group_by):
    """Collect git author identities grouped by pair, name, or email."""
    buckets = {}

    for _, author_name, author_email in iter_commit_entries(repo_path):
        if group_by == "pair":
            key = (normalize_text(author_name), normalize_text(author_email))
        elif group_by == "name":
            key = normalize_text(author_name)
        else:
            key = normalize_text(author_email)

        bucket = buckets.setdefault(
            key,
            {
                "commits": 0,
                "primary_name": author_name,
                "primary_email": author_email,
                "names": {},
                "emails": {},
            },
        )
        bucket["commits"] += 1
        bucket["names"].setdefault(normalize_text(author_name), author_name)
        bucket["emails"].setdefault(normalize_text(author_email), author_email)

    summaries = []
    for bucket in buckets.values():
        summaries.append(
            AuthorSummary(
                commits=bucket["commits"],
                primary_name=bucket["primary_name"],
                primary_email=bucket["primary_email"],
                names=tuple(sorted(bucket["names"].values(), key=str.casefold)),
                emails=tuple(sorted(bucket["emails"].values(), key=str.casefold)),
            )
        )

    return summaries


def summarize_values(values):
    """Render multiple aliases in a compact string."""
    return ", ".join(values)


def resolved_sort_order(sort_by, order):
    """Resolve the effective sort order."""
    if order is not None:
        return order
    return "desc" if sort_by == "commits" else "asc"


def sort_author_summaries(summaries, sort_by, order):
    """Sort grouped author summaries."""
    effective_order = resolved_sort_order(sort_by, order)

    if sort_by == "commits":
        if effective_order == "desc":
            return sorted(
                summaries,
                key=lambda item: (
                    -item.commits,
                    item.primary_name.casefold(),
                    item.primary_email.casefold(),
                ),
            )
        return sorted(
            summaries,
            key=lambda item: (
                item.commits,
                item.primary_name.casefold(),
                item.primary_email.casefold(),
            ),
        )

    key_func = (
        (lambda item: (item.primary_name.casefold(), item.primary_email.casefold(), -item.commits))
        if sort_by == "name"
        else (lambda item: (item.primary_email.casefold(), item.primary_name.casefold(), -item.commits))
    )
    return sorted(summaries, key=key_func, reverse=(effective_order == "desc"))


def summary_matches_search(summary, search_term):
    """Return whether a grouped summary matches a substring search."""
    if not search_term:
        return True

    normalized_query = normalize_text(search_term)
    haystacks = [summary.primary_name, summary.primary_email, *summary.names, *summary.emails]
    return any(normalized_query in normalize_text(value) for value in haystacks)


def scale_thresholds(thresholds, multiplier):
    """Scale threshold values by the configured multiplier."""
    return tuple(max(1, int(value * multiplier)) for value in thresholds)


def fibonacci_thresholds(max_value):
    """Return Fibonacci-ish thresholds up to max_value, appending max_value if needed."""
    if max_value <= 1:
        return (1,)

    thresholds = [1, 2]
    while True:
        next_value = thresholds[-1] + thresholds[-2]
        if next_value > max_value:
            break
        thresholds.append(next_value)

    if thresholds[-1] != max_value:
        thresholds.append(max_value)

    return tuple(thresholds)


def parse_scale_profile(profile_name, multiplier):
    """Parse a scale profile name into concrete thresholds."""
    match = SCALE_PROFILE_RE.fullmatch(profile_name)
    if not match:
        raise click.ClickException(
            "Invalid scale profile. Use names like linear-5-plus, "
            "linear-10-plus, fibonacci-8-plus, or fibonacci-21-plus."
        )

    kind = match.group("kind")
    max_value = int(match.group("max_value"))

    if kind == "linear":
        base_thresholds = tuple(range(1, max_value + 1))
    else:
        base_thresholds = fibonacci_thresholds(max_value)

    return ScaleProfile(
        name=profile_name,
        thresholds=scale_thresholds(base_thresholds, multiplier),
    )


def bucket_for_value(thresholds, input_value):
    """Create buckets from thresholds and return the bucket index."""
    for index, value in enumerate(thresholds):
        if input_value <= value:
            return index + 1
    return len(thresholds)


def hex_to_rgb(color):
    """Convert a #RRGGBB color to an RGB tuple."""
    color = color.lstrip("#")
    return tuple(int(color[index : index + 2], 16) for index in (0, 2, 4))


def rgb_to_hex(rgb):
    """Convert an RGB tuple to #RRGGBB."""
    return "#{:02x}{:02x}{:02x}".format(*rgb)


def _rgb_to_lab_l(rgb):
    """Approximate CIELAB L* luminance from an RGB tuple.

    Uses a simplified perceptual luminance model. Not a full CIELAB
    conversion, but good enough for perceptually-aware interpolation.
    """
    r, g, b = (c / 255.0 for c in rgb)
    # Linearize
    r = r ** 2.2 if r > 0.04045 else r / 12.92
    g = g ** 2.2 if g > 0.04045 else g / 12.92
    b = b ** 2.2 if b > 0.04045 else b / 12.92
    # Relative luminance (ITU-R BT.709)
    return 0.2126 * r + 0.7152 * g + 0.0722 * b


def _lab_l_to_rgb(lum):
    """Approximate RGB from a perceptual luminance value."""
    lum = max(0.0, min(1.0, lum))
    # Inverse gamma
    c = lum ** (1 / 2.2) if lum > 0.04045 else lum * 12.92
    return max(0, min(255, int(round(c * 255))))


def interpolate_color_perceptual(start_color, end_color, fraction):
    """Interpolate between two hex colors with perceptual luminance awareness.

    Instead of naive RGB interpolation (which can produce muddy mid-tones),
    this blends in a luminance-aware space for smoother, more uniform transitions.
    """
    start_rgb = hex_to_rgb(start_color)
    end_rgb = hex_to_rgb(end_color)

    start_l = _rgb_to_lab_l(start_rgb)
    end_l = _rgb_to_lab_l(end_rgb)

    # Blend luminance perceptually
    blended_l = start_l + (end_l - start_l) * fraction

    # For hue preservation, still do per-channel interpolation but
    # re-apply the blended luminance to keep saturation consistent.
    r = _lab_l_to_rgb(start_l + (end_l - start_l) * fraction)

    # Interpolate saturation-aware: keep the channel ratios from the
    # start/end but scale by the blended luminance.
    start_max = max(start_rgb)
    end_max = max(end_rgb)

    if start_max == 0 and end_max == 0:
        return (0, 0, 0)

    ratio = start_max / end_max if end_max > 0 else 1.0

    result = []
    for s_ch, e_ch in zip(start_rgb, end_rgb):
        # Perceptual blend: weighted by luminance
        perceptual = s_ch + (e_ch - s_ch) * fraction
        # Adjust by luminance ratio for consistency
        adjusted = perceptual * (blended_l / max(start_l, 0.001))
        result.append(max(0, min(255, int(round(adjusted)))))

    return rgb_to_hex(tuple(result))


def interpolate_color(start_color, end_color, fraction):
    """Interpolate between two hex colors."""
    start_rgb = hex_to_rgb(start_color)
    end_rgb = hex_to_rgb(end_color)
    blended = tuple(
        int(round(start_channel + ((end_channel - start_channel) * fraction)))
        for start_channel, end_channel in zip(start_rgb, end_rgb)
    )
    return rgb_to_hex(blended)


def generate_color_scale(stops, count):
    """Generate a color scale of the requested size from multi-stop anchors.

    Uses perceptual interpolation for smoother, more uniform transitions
    between color stops. The first stop is the least intense (low activity),
    the last stop is the most intense (high activity).
    """
    if count <= 0:
        return tuple()
    if count == 1:
        return (stops[0],)

    result = []
    segment_count = len(stops) - 1
    for index in range(count):
        position = index / (count - 1)
        segment_position = position * segment_count
        left_index = min(segment_count - 1, int(math.floor(segment_position)))
        right_index = min(len(stops) - 1, left_index + 1)
        fraction = segment_position - left_index
        result.append(interpolate_color_perceptual(stops[left_index], stops[right_index], fraction))
    return tuple(result)


def canonical_color_profile_name(profile_name, dark_mode):
    """Normalize a color profile name for internal lookup."""
    normalized = profile_name.strip().casefold()
    if normalized == "catppuccin":
        return "catppuccin-mocha" if dark_mode else "catppuccin-latte"
    return normalized


def resolve_color_profile(profile_name, dark_mode):
    """Resolve a color profile name to the theme-specific palette data."""
    canonical_name = canonical_color_profile_name(profile_name, dark_mode)
    if canonical_name not in COLOR_PROFILES:
        raise click.ClickException(
            f"Unknown color profile: {profile_name!r}. "
            f"Valid profiles: {COLOR_PROFILE_NAMES_HELP}"
        )

    profile = COLOR_PROFILES[canonical_name]
    return profile["dark" if dark_mode else "light"]


def load_palette(dark_mode, cell_count, color_profile):
    """Return the render palette."""
    profile = resolve_color_profile(color_profile, dark_mode)
    cells = profile["cells"]
    if len(cells) < cell_count:
        cells = cells + (cells[-1],) * (cell_count - len(cells))
    else:
        cells = cells[:cell_count]

    return Palette(
        background=profile["background"],
        text=profile["text"],
        subtle_text=profile["subtle_text"],
        empty_cell=profile["empty_cell"],
        out_of_range_cell=profile["out_of_range_cell"],
        cells=cells,
    )


def iter_dates(start_day, end_day):
    """Yield dates from start_day to end_day, inclusive."""
    current = start_day
    while current <= end_day:
        yield current
        current += timedelta(days=1)


def sunday_on_or_before(day_value):
    """Return the Sunday on or before the given date."""
    return day_value - timedelta(days=(day_value.weekday() + 1) % 7)


def saturday_on_or_after(day_value):
    """Return the Saturday on or after the given date."""
    return day_value + timedelta(days=(5 - day_value.weekday()) % 7)


def day_to_row_index(day_value):
    """Map a date to a hitmap row index where Sunday is row 0."""
    return (day_value.weekday() + 1) % 7


def format_section_label(start_date, end_date, exact_dates=False):
    """Format a section label for the hitmap."""
    if exact_dates:
        return f"{start_date:%Y-%m-%d} - {end_date:%Y-%m-%d}"
    return f"{start_date:%Y} - {end_date:%Y}"


def build_year_section(day_counts, start_date, end_date, label=None):
    """Create the visible week matrix and month labels for a date slice."""
    visible_start = sunday_on_or_before(start_date.date())
    visible_end = saturday_on_or_after(end_date.date())
    week_count = ((visible_end - visible_start).days + 1) // 7

    visible_counts = {}
    for current in iter_dates(start_date.date(), end_date.date()):
        commit_count = day_counts.get(current.isoformat(), 0)
        if commit_count <= 0:
            continue

        week_index = (current - visible_start).days // 7
        row_index = day_to_row_index(current)
        visible_counts[(week_index, row_index)] = commit_count

    month_labels = []
    last_labeled_week = None
    for current in iter_dates(start_date.date(), end_date.date()):
        week_index = (current - visible_start).days // 7
        should_label = current == start_date.date() or current.day == 1
        if should_label and week_index != last_labeled_week:
            month_labels.append((week_index, current.strftime("%b")))
            last_labeled_week = week_index

    return YearSection(
        label=label or format_section_label(start_date, end_date),
        range_start=start_date.date(),
        range_end=end_date.date(),
        visible_start=visible_start,
        visible_end=visible_end,
        week_count=week_count,
        month_labels=tuple(month_labels),
        day_counts=visible_counts,
    )


def normalize_date_floor(input_datetime):
    """Normalize a datetime-like input to a naive local midnight datetime."""
    return datetime.combine(input_datetime.date(), datetime.min.time())


def shift_date_by_months(day_value, months):
    """Shift a date by a calendar-month delta."""
    month_index = (day_value.year * 12) + (day_value.month - 1) + months
    year = month_index // 12
    month = (month_index % 12) + 1
    day = min(day_value.day, calendar.monthrange(year, month)[1])
    return date(year, month, day)


def shift_datetime_back(input_datetime, amount, unit):
    """Shift a datetime backward by the requested duration string."""
    if unit == "d":
        return normalize_date_floor(input_datetime - timedelta(days=amount))
    if unit == "w":
        return normalize_date_floor(input_datetime - timedelta(weeks=amount))
    if unit == "m":
        return datetime.combine(
            shift_date_by_months(input_datetime.date(), -amount), datetime.min.time()
        )
    if unit == "y":
        return datetime.combine(
            shift_date_by_months(input_datetime.date(), -(amount * 12)), datetime.min.time()
        )
    raise click.ClickException("Invalid --last unit")


def parse_last_window(last_value):
    """Parse the --last window value."""
    match = LAST_WINDOW_RE.fullmatch(last_value.strip())
    if not match:
        raise click.ClickException(
            "Invalid --last value. Use forms like 90d, 12w, 6m, or 1y."
        )

    return int(match.group("amount")), match.group("unit").lower()


def resolve_period_window(from_date, to_date, last_value):
    """Resolve the requested render time window."""
    if last_value is not None and from_date is not None:
        raise click.ClickException("--last cannot be combined with --from")

    if from_date is None and to_date is not None and last_value is None:
        raise click.ClickException("--to requires --from or --last")

    resolved_to = normalize_date_floor(to_date or datetime.now())

    if from_date is not None:
        resolved_from = normalize_date_floor(from_date)
        if resolved_from > resolved_to:
            raise click.ClickException("--from must be on or before --to")
        return PeriodWindow(
            start=resolved_from,
            end=resolved_to,
            exact=True,
            source="explicit range",
        )

    amount, unit = parse_last_window(last_value or DEFAULT_LAST_WINDOW)
    resolved_from = shift_datetime_back(resolved_to, amount, unit)
    if resolved_from > resolved_to:
        raise click.ClickException("Resolved date window is invalid")

    return PeriodWindow(
        start=resolved_from,
        end=resolved_to,
        exact=False,
        source=f"last {amount}{unit}",
    )


def build_sections_for_explicit_range(day_counts, start_date, end_date):
    """Split an explicit date range into year-bounded sections."""
    sections = []
    current_start = start_date.date()
    final_end = end_date.date()

    while current_start <= final_end:
        current_end = min(date(current_start.year, 12, 31), final_end)
        section_start = datetime.combine(current_start, datetime.min.time())
        section_end = datetime.combine(current_end, datetime.min.time())
        sections.append(
            build_year_section(
                day_counts,
                section_start,
                section_end,
                label=format_section_label(section_start, section_end, exact_dates=True),
            )
        )
        current_start = current_end + timedelta(days=1)

    return sections


def build_sections_for_period(day_counts, period_window):
    """Build render sections for either an exact or rolling window."""
    if period_window.exact:
        return build_sections_for_explicit_range(
            day_counts, period_window.start, period_window.end
        )

    return [
        build_year_section(
            day_counts,
            period_window.start,
            period_window.end,
            label=format_section_label(
                period_window.start, period_window.end, exact_dates=True
            ),
        )
    ]


def text_size(font, text):
    """Measure text using the Pillow font."""
    bbox = font.getbbox(text)
    return bbox[2] - bbox[0], bbox[3] - bbox[1]


def scaled_px(value, render_scale, minimum=1):
    """Scale a layout value from display pixels to raster pixels."""
    return max(minimum, int(round(value * render_scale)))


def load_render_font(render_scale, base_font_size_px=BASE_FONT_SIZE_PX):
    """Load a scalable font for the requested render scale."""
    font_size = scaled_px(base_font_size_px, render_scale)
    for candidate in FONT_CANDIDATES:
        try:
            return ImageFont.truetype(candidate, size=font_size)
        except OSError:
            continue
    return ImageFont.load_default()


def draw_cell(draw, x0, y0, size, fill):
    """Draw a single hitmap cell."""
    x1 = x0 + size - 1
    y1 = y0 + size - 1
    draw.rectangle((x0, y0, x1, y1), fill=fill)


def legend_item_width(label, font, legend_cell_size, item_padding):
    """Return the rendered width of a legend item without any inter-item gap."""
    label_width, _ = text_size(font, label)
    return legend_cell_size + item_padding + label_width


def legend_line_width(items, font, legend_cell_size, item_padding, item_gap):
    """Return the rendered width of a whole legend line."""
    if not items:
        return 0

    return sum(
        legend_item_width(label, font, legend_cell_size, item_padding)
        for label, _ in items
    ) + (max(0, len(items) - 1) * item_gap)


def build_legend_lines(items, font, legend_cell_size, max_width, item_padding, item_gap):
    """Wrap legend items to fit the canvas width."""
    lines = []
    current_line = []
    current_width = 0
    for label, color in items:
        item_width = legend_item_width(label, font, legend_cell_size, item_padding)
        proposed_width = item_width
        if current_line:
            proposed_width = current_width + item_gap + item_width

        if current_line and proposed_width > max_width:
            lines.append(current_line)
            current_line = []
            current_width = 0

        current_line.append((label, color))
        current_width = item_width if len(current_line) == 1 else proposed_width

    if current_line:
        lines.append(current_line)

    return lines


def render_hitmap_png(
    sections,
    scale_profile,
    dark_mode,
    max_display_width_px,
    render_scale,
    color_profile="github",
    geometry=None,
):
    """Render the hitmap image to PNG bytes."""
    if not sections:
        raise click.ClickException("No hitmap sections were generated")

    palette = load_palette(dark_mode, len(scale_profile.thresholds), color_profile)

    # Derive font size from terminal cell height so text matches terminal text size,
    # regardless of how wide the image is. Target ~60% of cell height.
    if geometry is not None and geometry.cell_height_px > 0:
        base_font_size = geometry.cell_height_px * 0.6
    else:
        base_font_size = BASE_FONT_SIZE_PX
    font = load_render_font(render_scale, base_font_size)
    line_height = text_size(font, "Ag")[1]

    # Use the terminal-derived width directly; no arbitrary hardcoded cap.
    effective_max_display = max_display_width_px

    max_raster_width_px = max(1, int(round(effective_max_display * render_scale)))

    max_weeks = max(section.week_count for section in sections)
    outer_padding_x = scaled_px(16, render_scale)
    outer_padding_y = scaled_px(14, render_scale)
    row_label_width = max(text_size(font, label)[0] for label in DAY_LABELS.values())
    row_label_gap = scaled_px(8, render_scale)
    grid_gap = scaled_px(3 if max_display_width_px >= 720 else 2, render_scale)
    available_grid_width = (
        max_raster_width_px - (outer_padding_x * 2) - row_label_width - row_label_gap
    )
    if available_grid_width <= 0:
        raise click.ClickException("Terminal is too narrow for hitmap")

    # Keep day boxes at the same size as a typical full-year hitmap so
    # short explicit ranges render narrower instead of inflating each box.
    reference_weeks = max(max_weeks, LOCKED_CELL_REFERENCE_WEEKS)
    cell_size = (
        available_grid_width - ((reference_weeks - 1) * grid_gap)
    ) // reference_weeks
    if cell_size < scaled_px(3, render_scale):
        raise click.ClickException(
            "Terminal is too narrow for an image hitmap; use a wider terminal"
        )

    section_title_height = line_height + scaled_px(10, render_scale)
    month_row_height = line_height + scaled_px(6, render_scale)
    grid_height = (7 * cell_size) + (6 * grid_gap)
    section_gap = line_height + scaled_px(14, render_scale)
    legend_top_gap = line_height + scaled_px(6, render_scale)
    grid_left = outer_padding_x + row_label_width + row_label_gap
    legend_cell_size = max(
        scaled_px(8, render_scale),
        min(cell_size, scaled_px(14, render_scale)),
    )
    legend_item_padding = scaled_px(4, render_scale)
    legend_item_gap = scaled_px(12, render_scale)
    grid_width = (max_weeks * cell_size) + (max(0, max_weeks - 1) * grid_gap)

    legend_items = [("n/a", palette.out_of_range_cell), ("0", palette.empty_cell)]
    for index, threshold in enumerate(scale_profile.thresholds, start=1):
        label = f"{threshold}+" if index == len(scale_profile.thresholds) else str(threshold)
        legend_items.append((label, palette.cells[index - 1]))

    max_section_label_width = max(text_size(font, section.label)[0] for section in sections)
    preferred_legend_width = legend_line_width(
        legend_items,
        font,
        legend_cell_size,
        legend_item_padding,
        legend_item_gap,
    )
    raster_width_px = min(
        max_raster_width_px,
        max(
            grid_left + grid_width + outer_padding_x,
            max_section_label_width + (outer_padding_x * 2),
            preferred_legend_width + (outer_padding_x * 2),
        ),
    )
    legend_lines = build_legend_lines(
        legend_items,
        font,
        legend_cell_size,
        raster_width_px - (outer_padding_x * 2),
        legend_item_padding,
        legend_item_gap,
    )
    legend_line_height = max(legend_cell_size, line_height) + scaled_px(6, render_scale)
    legend_height = line_height + scaled_px(6, render_scale) + (
        len(legend_lines) * legend_line_height
    )

    image_height = (
        outer_padding_y
        + len(sections) * (section_title_height + month_row_height + grid_height)
        + max(0, len(sections) - 1) * section_gap
        + legend_top_gap
        + legend_height
        + outer_padding_y
    )

    image = Image.new("RGBA", (raster_width_px, image_height), palette.background)
    draw = ImageDraw.Draw(image)

    current_y = outer_padding_y
    for section in sections:
        draw.text((outer_padding_x, current_y), section.label, fill=palette.text, font=font)

        month_y = current_y + section_title_height
        grid_y = month_y + month_row_height

        last_month_right = -999
        for week_index, month_label in section.month_labels:
            x = grid_left + week_index * (cell_size + grid_gap)
            month_width, _ = text_size(font, month_label)
            if x <= last_month_right + scaled_px(4, render_scale):
                continue
            draw.text((x, month_y), month_label, fill=palette.subtle_text, font=font)
            last_month_right = x + month_width

        for row_index, day_label in DAY_LABELS.items():
            label_y = (
                grid_y
                + row_index * (cell_size + grid_gap)
                + max((cell_size - line_height) // 2, 0)
            )
            draw.text((outer_padding_x, label_y), day_label, fill=palette.subtle_text, font=font)

        for week_index in range(section.week_count):
            column_x = grid_left + week_index * (cell_size + grid_gap)
            for row_index in range(7):
                cell_date = section.visible_start + timedelta(days=(week_index * 7) + row_index)
                if cell_date < section.range_start or cell_date > section.range_end:
                    color = palette.out_of_range_cell
                else:
                    count = section.day_counts.get((week_index, row_index), 0)
                    color = palette.empty_cell
                    if count > 0:
                        color = palette.cells[
                            bucket_for_value(scale_profile.thresholds, count) - 1
                        ]
                cell_y = grid_y + row_index * (cell_size + grid_gap)
                draw_cell(draw, column_x, cell_y, cell_size, color)

        current_y += section_title_height + month_row_height + grid_height + section_gap

    current_y -= section_gap
    legend_title_y = current_y + legend_top_gap
    draw.text((outer_padding_x, legend_title_y), "Legend", fill=palette.text, font=font)
    legend_y = legend_title_y + line_height + scaled_px(6, render_scale)

    for line_items in legend_lines:
        line_x = outer_padding_x
        for index, (label, color) in enumerate(line_items):
            draw_cell(draw, line_x, legend_y, legend_cell_size, color)
            text_x = line_x + legend_cell_size + legend_item_padding
            text_y = legend_y + max((legend_cell_size - line_height) // 2, 0)
            draw.text((text_x, text_y), label, fill=palette.subtle_text, font=font)
            line_x = text_x + text_size(font, label)[0]
            if index != len(line_items) - 1:
                line_x += legend_item_gap
        legend_y += legend_line_height

    buffer = io.BytesIO()
    image.save(buffer, format="PNG")
    return RenderResult(
        png_bytes=buffer.getvalue(),
        width_px=image.width,
        height_px=image.height,
        display_width_px=max(1, int(round(image.width / render_scale))),
    )


def scan_terminal_responses(buffer):
    """Detect whether the tty buffer contains graphics and DA responses."""
    graphics_seen = False
    graphics_index = buffer.find(GRAPHICS_RESPONSE_START)
    if graphics_index != -1:
        graphics_end = buffer.find(GRAPHICS_RESPONSE_END, graphics_index)
        graphics_seen = graphics_end != -1

    device_attributes_seen = DEVICE_ATTRIBUTES_RESPONSE_RE.search(buffer) is not None
    return graphics_seen, device_attributes_seen


def probe_kitty_graphics_support(fd, timeout_seconds=0.35):
    """Probe whether the active terminal supports the kitty graphics protocol."""
    old_termios = termios.tcgetattr(fd)
    try:
        tty.setraw(fd, termios.TCSANOW)
        termios.tcflush(fd, termios.TCIFLUSH)
        write_all(fd, GRAPHICS_QUERY + PRIMARY_DEVICE_ATTRIBUTES_QUERY)

        buffer = bytearray()
        graphics_seen = False
        deadline = time.monotonic() + timeout_seconds
        while time.monotonic() < deadline:
            remaining = max(0.0, deadline - time.monotonic())
            readable, _, _ = select.select([fd], [], [], remaining)
            if not readable:
                break
            chunk = os.read(fd, 4096)
            if not chunk:
                break
            buffer.extend(chunk)
            graphics_seen, _ = scan_terminal_responses(buffer)

        termios.tcflush(fd, termios.TCIFLUSH)
        return graphics_seen
    finally:
        termios.tcsetattr(fd, termios.TCSANOW, old_termios)


def get_terminal_geometry(fd):
    """Return terminal rows/cols and pixel geometry if available."""
    rows = 24
    cols = 80
    width_px = 0
    height_px = 0

    try:
        packed = fcntl.ioctl(fd, termios.TIOCGWINSZ, struct.pack(WINSIZE_STRUCT, 0, 0, 0, 0))
        rows, cols, width_px, height_px = struct.unpack(WINSIZE_STRUCT, packed)
    except OSError:
        size = os.get_terminal_size(fd)
        cols = size.columns
        rows = size.lines

    if rows <= 0 or cols <= 0:
        size = os.get_terminal_size(fd)
        cols = size.columns
        rows = size.lines

    cell_width_px = width_px / cols if width_px > 0 and cols > 0 else DEFAULT_CELL_WIDTH_PX
    cell_height_px = (
        height_px / rows if height_px > 0 and rows > 0 else DEFAULT_CELL_HEIGHT_PX
    )

    return TerminalGeometry(
        rows=rows,
        cols=cols,
        width_px=width_px,
        height_px=height_px,
        cell_width_px=max(cell_width_px, 1.0),
        cell_height_px=max(cell_height_px, 1.0),
    )


def resolve_width_cells(requested_width_cells, geometry):
    """Resolve the maximum image width in terminal cells.

    Uses 90% of the terminal's pixel width converted to column count,
    capped by the terminal's column count minus one.
    """
    hard_max_width = max(1, geometry.cols - 1)
    if requested_width_cells is not None:
        return max(1, min(requested_width_cells, hard_max_width))

    # 90% of terminal width converted to column cells
    if geometry.width_px > 0:
        max_cols = max(1, int(math.floor(geometry.width_px * 0.9 / geometry.cell_width_px)))
    else:
        max_cols = max(1, int(math.floor(geometry.cols * 0.9)))

    return max(1, min(max_cols, hard_max_width))


def encode_kitty_chunks(
    png_bytes, placement_cols, placement_rows=None, cursor_no_move=True, chunk_size=4096
):
    """Encode a PNG for transport with the kitty graphics protocol."""
    if chunk_size <= 0 or chunk_size % 4 != 0:
        raise ValueError("chunk_size must be a positive multiple of 4")

    encoded = base64.standard_b64encode(png_bytes)
    control_prefix = f"a=T,t=d,f=100,c={placement_cols}"
    if placement_rows is not None:
        control_prefix += f",r={placement_rows}"
    if cursor_no_move:
        control_prefix += ",C=1"

    chunks = []
    for offset in range(0, len(encoded), chunk_size):
        payload = encoded[offset : offset + chunk_size]
        more = 1 if offset + chunk_size < len(encoded) else 0
        if offset == 0:
            control = f"{control_prefix},m={more};".encode("ascii")
        else:
            control = f"m={more};".encode("ascii")
        chunks.append(b"\x1b_G" + control + payload + b"\x1b\\")

    if not chunks:
        chunks.append((f"\x1b_G{control_prefix},m=0;\x1b\\").encode("ascii"))

    return chunks


def write_all(fd, data):
    """Write all bytes to a file descriptor."""
    remaining = data
    while remaining:
        written = os.write(fd, remaining)
        remaining = remaining[written:]


def resolve_target_width_px(placement_cols, geometry):
    """Resolve the maximum display width in pixels for the rendered image."""
    target_width_px = max(1, int(round(placement_cols * geometry.cell_width_px)))
    if geometry.width_px > 0:
        target_width_px = min(target_width_px, geometry.width_px)
    return target_width_px


def resolve_placement_cols(display_width_px, max_width_cells, geometry):
    """Resolve the final displayed image width in terminal cells."""
    placement_cols = max(1, int(round(display_width_px / geometry.cell_width_px)))
    return max(1, min(placement_cols, max_width_cells))


def display_png_via_kitty(fd, png_bytes, placement_cols, placement_rows=None):
    """Display a PNG using kitty graphics and leave the prompt below the image."""
    write_all(fd, b"\r")
    for chunk in encode_kitty_chunks(
        png_bytes,
        placement_cols,
        placement_rows=placement_rows,
        cursor_no_move=False,
    ):
        write_all(fd, chunk)
    write_all(fd, b"\r")
    termios.tcdrain(fd)


@contextlib.contextmanager
def open_render_tty():
    """Open the controlling TTY for direct terminal I/O during render."""
    if not sys.stdin.isatty() or not sys.stdout.isatty():
        raise click.ClickException(
            "hitmap render requires an interactive terminal"
        )

    try:
        fd = os.open("/dev/tty", os.O_RDWR | os.O_NOCTTY)
    except OSError as exc:
        raise click.ClickException(
            "Unable to access the controlling terminal for image output"
        ) from exc

    try:
        yield fd
    finally:
        os.close(fd)


def guess_dark_theme():
    """Best-effort theme guess from terminal environment variables."""
    colorfgbg = os.getenv("COLORFGBG", "")
    if colorfgbg:
        try:
            background = int(colorfgbg.split(";")[-1])
            return background < 8
        except ValueError:
            pass
    return False


def resolve_dark_mode(theme):
    """Resolve the requested theme option to a boolean dark-mode flag."""
    if theme == "dark":
        return True
    if theme == "light":
        return False
    return guess_dark_theme()


def render_authors_table(repo_path, summaries, sort_by, order, group_by):
    """Render the authors command as a Rich table."""
    effective_order = resolved_sort_order(sort_by, order)
    repo_name = os.path.basename(repo_path.rstrip(os.sep)) or repo_path
    table = Table(
        title=f"Authors · {repo_name}",
        caption=f"sort={sort_by} order={effective_order} group={group_by} entries={len(summaries)}",
    )
    table.add_column("Commits", justify="right", style="cyan")

    if group_by == "pair":
        table.add_column("Author Name", style="bold")
        table.add_column("Author Email", style="magenta")
        for summary in summaries:
            table.add_row(
                str(summary.commits),
                summary.primary_name,
                summary.primary_email,
            )
    elif group_by == "name":
        table.add_column("Author Name", style="bold")
        table.add_column("Emails", style="magenta")
        for summary in summaries:
            table.add_row(
                str(summary.commits),
                summary.primary_name,
                summarize_values(summary.emails),
            )
    else:
        table.add_column("Author Email", style="magenta")
        table.add_column("Names", style="bold")
        for summary in summaries:
            table.add_row(
                str(summary.commits),
                summary.primary_email,
                summarize_values(summary.names),
            )

    CONSOLE.print(table)


def author_summaries_to_json(summaries, sort_by, order, group_by, repo_path):
    """Serialize author summaries as JSON."""
    return {
        "repo": repo_path,
        "sort": sort_by,
        "order": resolved_sort_order(sort_by, order),
        "group_by": group_by,
        "entries": [
            {
                "commits": summary.commits,
                "primary_name": summary.primary_name,
                "primary_email": summary.primary_email,
                "names": list(summary.names),
                "emails": list(summary.emails),
            }
            for summary in summaries
        ],
    }


def render_authors_tsv(summaries, group_by):
    """Render the authors command as tab-separated output."""
    if group_by == "pair":
        click.echo("commits\tname\temail")
        for summary in summaries:
            click.echo(f"{summary.commits}\t{summary.primary_name}\t{summary.primary_email}")
        return

    if group_by == "name":
        click.echo("commits\tname\temails")
        for summary in summaries:
            click.echo(f"{summary.commits}\t{summary.primary_name}\t{summarize_values(summary.emails)}")
        return

    click.echo("commits\temail\tnames")
    for summary in summaries:
        click.echo(f"{summary.commits}\t{summary.primary_email}\t{summarize_values(summary.names)}")


def render_doctor_table(checks):
    """Render terminal diagnostics as a Rich table."""
    table = Table(title="Doctor")
    table.add_column("Check", style="bold")
    table.add_column("Status")
    table.add_column("Detail")

    for check in checks:
        status = "[green]OK[/green]" if check.ok else "[red]FAIL[/red]"
        table.add_row(check.name, status, check.detail)

    CONSOLE.print(table)


def doctor_checks_to_json(checks):
    """Serialize doctor results as JSON."""
    return {
        "checks": [
            {"name": check.name, "ok": check.ok, "detail": check.detail}
            for check in checks
        ]
    }


def collect_doctor_checks():
    """Collect terminal diagnostics without requiring a successful probe."""
    checks = [
        DoctorCheck(
            name="stdin tty",
            ok=sys.stdin.isatty(),
            detail="interactive" if sys.stdin.isatty() else "not a tty",
        ),
        DoctorCheck(
            name="stdout tty",
            ok=sys.stdout.isatty(),
            detail="interactive" if sys.stdout.isatty() else "not a tty",
        ),
        DoctorCheck(
            name="terminal program",
            ok=True,
            detail=os.getenv("TERM_PROGRAM") or os.getenv("TERM") or "unknown",
        ),
        DoctorCheck(
            name="theme guess",
            ok=True,
            detail="dark" if guess_dark_theme() else "light",
        ),
    ]

    tty_fd = None
    try:
        tty_fd = os.open("/dev/tty", os.O_RDWR | os.O_NOCTTY)
    except OSError as exc:
        checks.append(
            DoctorCheck(name="controlling tty", ok=False, detail=str(exc))
        )
        return checks

    checks.append(DoctorCheck(name="controlling tty", ok=True, detail="/dev/tty available"))

    try:
        geometry = get_terminal_geometry(tty_fd)
        geometry_detail = f"{geometry.cols} cols × {geometry.rows} rows"
        if geometry.width_px > 0 and geometry.height_px > 0:
            geometry_detail += f" · {geometry.width_px}px × {geometry.height_px}px"
        checks.append(DoctorCheck(name="terminal geometry", ok=True, detail=geometry_detail))
        checks.append(
            DoctorCheck(
                name="cell size",
                ok=True,
                detail=f"{geometry.cell_width_px:.1f}px × {geometry.cell_height_px:.1f}px",
            )
        )
        kitty_supported = probe_kitty_graphics_support(tty_fd)
        checks.append(
            DoctorCheck(
                name="kitty graphics",
                ok=kitty_supported,
                detail=(
                    "probe succeeded"
                    if kitty_supported
                    else "probe timed out or terminal does not support kitty graphics"
                ),
            )
        )
    finally:
        os.close(tty_fd)

    return checks


def print_render_summary(
    repo_path,
    selection,
    period_window,
    scale_profile,
    scale_multiplier,
    render_scale,
    theme,
    color_profile,
    total_commits,
    matched_identities,
):
    """Print a Rich summary for verbose render mode."""
    table = Table(show_header=False)
    table.add_column(style="bold")
    table.add_column()
    table.add_row("Repo", repo_path)
    table.add_row("Authors", describe_author_selection(selection))
    table.add_row(
        "Period",
        f"{period_window.start:%Y-%m-%d} → {period_window.end:%Y-%m-%d} ({period_window.source})",
    )
    table.add_row("Scale profile", scale_profile.name)
    table.add_row("Scale multiplier", str(scale_multiplier))
    table.add_row("Render scale", str(render_scale))
    table.add_row("Theme", theme)
    table.add_row("Color profile", color_profile)
    table.add_row("Commits in range", str(total_commits))
    table.add_row("Matched identities", str(len(matched_identities)))
    ERR_CONSOLE.print(table)
    if total_commits == 0:
        ERR_CONSOLE.print("[yellow]No commits matched the selected author filter in this period.[/yellow]")


class DefaultToRenderGroup(click.Group):
    """A command group that treats bare invocations as `render ...`."""

    def parse_args(self, ctx, args):
        normalized_args = list(args)
        if (
            normalized_args
            and normalized_args[0] not in self.commands
            and normalized_args[0] not in ROOT_HELP_TOKENS
        ):
            normalized_args.insert(0, "render")
        return super().parse_args(ctx, normalized_args)


@click.group(
    cls=DefaultToRenderGroup,
    context_settings={"help_option_names": ["-h", "--help"]},
    no_args_is_help=True,
)
@click.version_option(version=VERSION)
def cli():
    """Render git hitmaps and inspect author identities.

    When no subcommand is given, hitmap defaults to `render`.
    """


@cli.command("render")
@click.argument(
    "repo_path",
    type=click.Path(exists=True, file_okay=False, path_type=str),
    default=".",
    required=False,
    metavar="[REPO]",
)
@click.option(
    "--all-authors",
    is_flag=True,
    help="Render commits for all authors (also the default if no author filter is given)",
)
@click.option(
    "--author-name",
    "author_names",
    multiple=True,
    help="Match an exact author name (repeatable, case-insensitive)",
)
@click.option(
    "--author-email",
    "author_emails",
    multiple=True,
    help="Match an exact author email (repeatable, case-insensitive)",
)
@click.option(
    "--from",
    "from_date",
    type=click.DateTime(formats=["%Y-%m-%d"]),
    default=None,
    help="Inclusive start date in YYYY-MM-DD format",
)
@click.option(
    "--to",
    "to_date",
    type=click.DateTime(formats=["%Y-%m-%d"]),
    default=None,
    help="Inclusive end date in YYYY-MM-DD format",
)
@click.option(
    "--last",
    default=None,
    help=f"Rolling window like 90d, 12w, 6m, or 1y (default: {DEFAULT_LAST_WINDOW})",
)
@click.option(
    "--scale-profile",
    default=DEFAULT_SCALE_PROFILE,
    show_default=True,
    help="Threshold profile, e.g. linear-5-plus, linear-10-plus, fibonacci-8-plus",
)
@click.option(
    "--scale-multiplier",
    type=click.IntRange(min=1),
    default=1,
    show_default=True,
    help="Multiply every threshold in the selected scale profile",
)
@click.option(
    "--max-width-cells",
    type=click.IntRange(min=1),
    default=None,
    help="Maximum image width in terminal cells",
)
@click.option(
    "--render-scale",
    type=click.FloatRange(min=1.0),
    default=DEFAULT_RENDER_SCALE,
    show_default=True,
    help="Render the PNG at a higher internal scale for sharper output",
)
@click.option(
    "--theme",
    type=click.Choice(["auto", "light", "dark"], case_sensitive=False),
    default="auto",
    show_default=True,
    help="Background theme (light or dark); color profiles work on both",
)
@click.option(
    "--color",
    default=DEFAULT_COLOR_PROFILE,
    show_default=True,
    help=f"Color profile for commit cells ({COLOR_PROFILE_NAMES_HELP})"
    " — works on any theme",
)
@click.option("--verbose", is_flag=True, help="Print render configuration and stats")
def render_command(
    repo_path,
    all_authors,
    author_names,
    author_emails,
    from_date,
    to_date,
    last,
    scale_profile,
    scale_multiplier,
    max_width_cells,
    render_scale,
    theme,
    color,
    verbose,
):
    """Render a git commit hitmap as an inline Kitty image."""
    resolved_repo_path = resolve_repo_root(repo_path)
    selection = resolve_author_selection(
        all_authors, author_names, author_emails, default_all=True
    )
    ensure_author_selection_exists(resolved_repo_path, selection)
    period_window = resolve_period_window(from_date, to_date, last)
    resolved_scale_profile = parse_scale_profile(scale_profile, scale_multiplier)
    dark_mode = resolve_dark_mode(theme)
    resolved_color_profile = canonical_color_profile_name(color, dark_mode)

    day_counts, total_commits, matched_identities = collect_commit_day_counts(
        resolved_repo_path,
        selection,
        period_window.start,
        period_window.end,
    )
    sections = build_sections_for_period(day_counts, period_window)

    if verbose:
        print_render_summary(
            resolved_repo_path,
            selection,
            period_window,
            resolved_scale_profile,
            scale_multiplier,
            render_scale,
            theme,
            resolved_color_profile,
            total_commits,
            matched_identities,
        )

    sys.stdout.flush()
    sys.stderr.flush()

    with open_render_tty() as tty_fd:
        if not probe_kitty_graphics_support(tty_fd):
            raise click.ClickException(
                "This terminal did not answer the Kitty graphics protocol query. "
                "Run `hitmap render` in kitty, Ghostty, or another compatible terminal."
            )

        geometry = get_terminal_geometry(tty_fd)
        max_placement_cols = resolve_width_cells(max_width_cells, geometry)
        max_display_width_px = resolve_target_width_px(max_placement_cols, geometry)
        rendered = render_hitmap_png(
            sections,
            scale_profile=resolved_scale_profile,
            dark_mode=dark_mode,
            max_display_width_px=max_display_width_px,
            render_scale=render_scale,
            color_profile=resolved_color_profile,
            geometry=geometry,
        )
        placement_cols = resolve_placement_cols(
            rendered.display_width_px, max_placement_cols, geometry
        )
        display_png_via_kitty(
            tty_fd,
            rendered.png_bytes,
            placement_cols=placement_cols,
            placement_rows=None,
        )


@cli.command("authors")
@click.argument(
    "repo_path",
    type=click.Path(exists=True, file_okay=False, path_type=str),
    default=".",
    required=False,
    metavar="[REPO]",
)
@click.option(
    "--sort",
    "sort_by",
    type=click.Choice(["commits", "name", "email"], case_sensitive=False),
    default="commits",
    show_default=True,
    help="Sort field",
)
@click.option(
    "--order",
    type=click.Choice(["asc", "desc"], case_sensitive=False),
    default=None,
    help="Sort order (default: desc for commits, asc otherwise)",
)
@click.option(
    "--group-by",
    type=click.Choice(["pair", "name", "email"], case_sensitive=False),
    default="pair",
    show_default=True,
    help="Identity grouping mode",
)
@click.option("--search", default=None, help="Case-insensitive substring filter")
@click.option(
    "--limit",
    type=click.IntRange(min=1),
    default=None,
    help="Limit the number of displayed rows",
)
@click.option(
    "--format",
    "output_format",
    type=click.Choice(["table", "json", "tsv"], case_sensitive=False),
    default="table",
    show_default=True,
    help="Output format",
)
def authors_command(repo_path, sort_by, order, group_by, search, limit, output_format):
    """List author identities reachable from the current HEAD history."""
    resolved_repo_path = resolve_repo_root(repo_path)
    summaries = collect_author_summaries(resolved_repo_path, group_by)
    summaries = [summary for summary in summaries if summary_matches_search(summary, search)]
    summaries = sort_author_summaries(summaries, sort_by, order)

    if limit is not None:
        summaries = summaries[:limit]

    if output_format == "json":
        click.echo(
            json.dumps(
                author_summaries_to_json(
                    summaries, sort_by, order, group_by, resolved_repo_path
                ),
                indent=2,
                ensure_ascii=False,
            )
        )
        return

    if output_format == "tsv":
        render_authors_tsv(summaries, group_by)
        return

    if not summaries:
        CONSOLE.print("[yellow]No authors matched the current filter.[/yellow]")
        return

    render_authors_table(resolved_repo_path, summaries, sort_by, order, group_by)


@cli.command("doctor")
@click.option(
    "--format",
    "output_format",
    type=click.Choice(["table", "json"], case_sensitive=False),
    default="table",
    show_default=True,
    help="Output format",
)
def doctor_command(output_format):
    """Check terminal support for Kitty image rendering."""
    checks = collect_doctor_checks()

    if output_format == "json":
        click.echo(json.dumps(doctor_checks_to_json(checks), indent=2, ensure_ascii=False))
        return

    render_doctor_table(checks)


